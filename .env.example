NODE_ENV=production
PORT=5000

# ── MongoDB Atlas (required) ───────────────────────────────────────────────
# mongodb+srv://username:password@cluster.mongodb.net/mern-auth
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/mern-auth?retryWrites=true&w=majority

# ── JWT Secrets (32+ chars, random) ───────────────────────────────────────
JWT_ACCESS_SECRET=change_this_to_random_32_char_string_prod
JWT_REFRESH_SECRET=change_this_to_another_random_32_char_string
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ── Email — Gmail SMTP ─────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM="AuthSystem <your_email@gmail.com>"

# ── URLs ───────────────────────────────────────────────────────────────────
# Backend নিজের URL (Railway দিলে দেওয়া হবে automatically)
# CLIENT_URL = Vercel frontend URL
# Multiple origins: comma separated
CLIENT_URL=https://your-app.vercel.app

# ── 2FA ───────────────────────────────────────────────────────────────────
TWO_FACTOR_APP_NAME=AuthSystem

# ── AI Fraud Detection (optional) ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Encryption ────────────────────────────────────────────────────────────
ENCRYPTION_KEY=exactly_32_characters_here_12345

# ── AI Fraud Detection — Gemini Free API (optional) ───────────────────────
# Get free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
