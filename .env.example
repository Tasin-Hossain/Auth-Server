NODE_ENV=development
PORT=5000

# MongoDB (required — change to your URI)
MONGODB_URI=mongodb://localhost:27017/mern-auth

# JWT Secrets (CHANGE THESE IN PRODUCTION — must be 32+ chars)
JWT_ACCESS_SECRET=dev_access_secret_key_change_in_prod_32ch
JWT_REFRESH_SECRET=dev_refresh_secret_key_change_in_prod_32c
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Email — Gmail SMTP (required for email features)
# To get Gmail App Password:
# 1. Enable 2FA on your Gmail
# 2. Google Account → Security → App Passwords → Generate
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM="AuthSystem <your_email@gmail.com>"

# Client URL (Vite default)
CLIENT_URL=http://localhost:5173

# 2FA Issuer name (shows in authenticator apps)
TWO_FACTOR_APP_NAME=AuthSystem

# AI Fraud Detection — Anthropic API (OPTIONAL)
# Leave empty to use heuristic-only detection
ANTHROPIC_API_KEY=

# Encryption key (32 chars exactly for AES-256)
ENCRYPTION_KEY=12345678901234567890123456789012
